---
// Self-hosted fonts (replaces render-blocking Google Fonts).
// Inter 400/500/600 (body) and Montserrat 500/600/700/800 (display),
// latin + latin-ext subsets (latin-ext is required for Slovenian š/č/ž).
import '@fontsource/inter/latin-400.css';
import '@fontsource/inter/latin-500.css';
import '@fontsource/inter/latin-600.css';
import '@fontsource/inter/latin-ext-400.css';
import '@fontsource/inter/latin-ext-500.css';
import '@fontsource/inter/latin-ext-600.css';
import '@fontsource/montserrat/latin-500.css';
import '@fontsource/montserrat/latin-600.css';
import '@fontsource/montserrat/latin-700.css';
import '@fontsource/montserrat/latin-800.css';
import '@fontsource/montserrat/latin-ext-500.css';
import '@fontsource/montserrat/latin-ext-600.css';
import '@fontsource/montserrat/latin-ext-700.css';
import '@fontsource/montserrat/latin-ext-800.css';

// Resolved (hashed) URLs for the above-the-fold fonts, used for preloading.
import interLatin400 from '@fontsource/inter/files/inter-latin-400-normal.woff2';
import interLatinExt400 from '@fontsource/inter/files/inter-latin-ext-400-normal.woff2';
import montserratLatin800 from '@fontsource/montserrat/files/montserrat-latin-800-normal.woff2';
import montserratLatinExt800 from '@fontsource/montserrat/files/montserrat-latin-ext-800-normal.woff2';

import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'BTON | Nizke gradnje in betonske površine | Bled, Slovenija',
  description = 'Urejate dvorišče, teraso ali dovoz? V podjetju BTON izdelamo betonsko površino, ki je lepa, uporabna in trajna — od priprave podlage do zadnjega premaza. Bled in okolica.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="sl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#1b1e23" />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="BTON" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="sl_SI" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Preload above-the-fold fonts (hero title + body) -->
    <link rel="preload" as="font" type="font/woff2" href={montserratLatin800} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={montserratLatinExt800} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={interLatin400} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={interLatinExt400} crossorigin />

    <!-- Structured data -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'GeneralContractor',
        name: 'BTON, nizke gradnje, Dejan Hodžić, s.p.',
        image: canonical + 'favicon.png',
        url: 'https://bton.si',
        telephone: '+386 30 638 685',
        email: 'info@bton.si',
        address: {
          '@type': 'PostalAddress',
          streetAddress: 'Kajuhova 19',
          postalCode: '4260',
          addressLocality: 'Bled',
          addressCountry: 'SI',
        },
        areaServed: 'Slovenija',
        description,
      })}
    />
  </head>
  <body>
    <slot />

    <script>
      // Scroll reveal
      const els = document.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add('is-visible'));
      }
    </script>
  </body>
</html>
