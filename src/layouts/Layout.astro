---
// Minimal self-hosted font set. Other weights are synthesized by the browser,
// which avoids downloading many small render-affecting font files.
import interLatin400 from '@fontsource/inter/files/inter-latin-400-normal.woff2';
import interLatinExt400 from '@fontsource/inter/files/inter-latin-ext-400-normal.woff2';
import montserratLatin800 from '@fontsource/montserrat/files/montserrat-latin-800-normal.woff2';
import montserratLatinExt800 from '@fontsource/montserrat/files/montserrat-latin-ext-800-normal.woff2';

import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  ogImage?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = 'BTON | Nizke gradnje in betonske površine | Bled, Slovenija',
  description = 'Strokovno izdelane zunanje betonske površine, kjer se estetika prepleta z vzdržljivostjo. V podjetju BTON ustvarjamo unikatne in celovite rešitve, prilagojene vašemu slogu in prostoru.',
  canonicalPath,
  ogImage = '/og-image.jpg',
  structuredData = [],
} = Astro.props;

const canonical = new URL(canonicalPath ?? Astro.url.pathname, Astro.site).href;
const absoluteOgImage = new URL(ogImage, Astro.site).href;
const structuredDataItems = Array.isArray(structuredData) ? structuredData : [structuredData];
const organizationData = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'GeneralContractor'],
  '@id': 'https://bton.si/#organization',
  name: 'BTON, nizke gradnje, Dejan Hodžić, s.p.',
  alternateName: 'BTON',
  image: absoluteOgImage,
  logo: new URL('/favicon.png', Astro.site).href,
  url: 'https://bton.si/',
  telephone: '+386 30 638 685',
  email: 'info@bton.si',
  priceRange: '$$',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Kajuhova 19',
    postalCode: '4260',
    addressLocality: 'Bled',
    addressCountry: 'SI',
  },
  areaServed: [
    { '@type': 'Country', name: 'Slovenija' },
    { '@type': 'AdministrativeArea', name: 'Gorenjska' },
  ],
  sameAs: ['https://www.facebook.com/bton.si'],
  description,
};
const websiteData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': 'https://bton.si/#website',
  url: 'https://bton.si/',
  name: 'BTON',
  inLanguage: 'sl-SI',
  publisher: { '@id': 'https://bton.si/#organization' },
};

const fontFaceCss = `
  @font-face {
    font-family: 'Inter';
    font-style: normal;
    font-display: optional;
    font-weight: 400 800;
    src: url('${interLatinExt400}') format('woff2');
    unicode-range: U+0100-02BA,U+02BD-02C5,U+02C7-02CC,U+02CE-02D7,U+02DD-02FF,U+0304,U+0308,U+0329,U+1D00-1DBF,U+1E00-1E9F,U+1EF2-1EFF,U+2020,U+20A0-20AB,U+20AD-20C0,U+2113,U+2C60-2C7F,U+A720-A7FF;
  }
  @font-face {
    font-family: 'Inter';
    font-style: normal;
    font-display: optional;
    font-weight: 400 800;
    src: url('${interLatin400}') format('woff2');
    unicode-range: U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD;
  }
  @font-face {
    font-family: 'Montserrat';
    font-style: normal;
    font-display: optional;
    font-weight: 500 900;
    src: url('${montserratLatinExt800}') format('woff2');
    unicode-range: U+0100-02BA,U+02BD-02C5,U+02C7-02CC,U+02CE-02D7,U+02DD-02FF,U+0304,U+0308,U+0329,U+1D00-1DBF,U+1E00-1E9F,U+1EF2-1EFF,U+2020,U+20A0-20AB,U+20AD-20C0,U+2113,U+2C60-2C7F,U+A720-A7FF;
  }
  @font-face {
    font-family: 'Montserrat';
    font-style: normal;
    font-display: optional;
    font-weight: 500 900;
    src: url('${montserratLatin800}') format('woff2');
    unicode-range: U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD;
  }
`;
---

<!doctype html>
<html lang="sl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="author" content="BTON, nizke gradnje, Dejan Hodžić, s.p." />
    <meta name="geo.region" content="SI-003" />
    <meta name="geo.placename" content="Bled" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="sl-SI" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#1b1e23" />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="BTON" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="sl_SI" />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="BTON — betonske površine in nizke gradnje" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />

    <style is:inline set:html={fontFaceCss}></style>

    <!-- Structured data -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify([organizationData, websiteData, ...structuredDataItems])}
    />
  </head>
  <body>
    <slot />

    <script>
      // Scroll reveal
      const els = document.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add('is-visible'));
      }
    </script>
  </body>
</html>
