---
// Self-hosted font. Archivo Variable ("standard" = weight + width axes)
// covers display, body and labels in a single file per subset.
// latin-ext is required for Slovenian š/č/ž.
import '@fontsource-variable/archivo/standard.css';

// Resolved (hashed) URLs for the above-the-fold fonts, used for preloading.
import archivoLatin from '@fontsource-variable/archivo/files/archivo-latin-standard-normal.woff2';
import archivoLatinExt from '@fontsource-variable/archivo/files/archivo-latin-ext-standard-normal.woff2';

import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'BTON | Nizke gradnje in betonske površine | Bled · Maribor',
  description = 'Urejate dvorišče, teraso ali dovoz? V podjetju BTON izdelamo betonsko površino, ki je lepa, uporabna in trajna — od prvega opaža do zadnjega premaza. Delujemo po vsej Sloveniji, iz Bleda in Maribora.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/og.jpg', Astro.site).href;
---

<!doctype html>
<html lang="sl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#1a1815" />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="BTON" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="sl_SI" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Tiskan betonski tlak z logotipom BTON" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Preload the above-the-fold font (hero title + body) -->
    <link rel="preload" as="font" type="font/woff2" href={archivoLatin} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={archivoLatinExt} crossorigin />

    <!-- Structured data -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'GeneralContractor',
        '@id': 'https://bton.si/#business',
        name: 'BTON, nizke gradnje, Dejan Hodžić, s.p.',
        image: ogImage,
        logo: new URL('/favicon.png', Astro.site).href,
        url: 'https://bton.si',
        telephone: '+386 30 638 685',
        email: 'info@bton.si',
        priceRange: '40–100 €/m²',
        address: {
          '@type': 'PostalAddress',
          streetAddress: 'Kajuhova 19',
          postalCode: '4260',
          addressLocality: 'Bled',
          addressCountry: 'SI',
        },
        geo: {
          '@type': 'GeoCoordinates',
          latitude: 46.3683,
          longitude: 14.1146,
        },
        areaServed: { '@type': 'Country', name: 'Slovenija' },
        sameAs: ['https://www.facebook.com/bton.si'],
        description,
      })}
    />

    <slot name="head" />
  </head>
  <body>
    <slot />

    <script>
      // Scroll reveal
      const els = document.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add('is-visible'));
      }
    </script>
  </body>
</html>
