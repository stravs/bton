---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

const modules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/images/gallery/*.{jpg,jpeg,png}',
  { eager: true }
);

const sorted = Object.keys(modules)
  .sort()
  .map((k) => modules[k].default);

// Mosaic slots: 1 = feature (2×2, prefers landscape), 2 & 5 = tall (prefer portrait).
// With 11 images this fills the 4-column grid exactly (16 cells = 4 rows).
const take = (pool: ImageMetadata[], pred: (i: ImageMetadata) => boolean) => {
  const idx = pool.findIndex(pred);
  return pool.splice(idx === -1 ? 0 : idx, 1)[0];
};
const pool = [...sorted];
const feature = take(pool, (i) => i.width >= i.height);
const tallA = take(pool, (i) => i.height > i.width);
const singles = pool.splice(0, 2);
const tallB = take(pool, (i) => i.height > i.width);
const images = [feature, tallA, ...singles, tallB, ...pool].filter(Boolean);
---

<section class="section section--soft" id="galerija">
  <div class="container container--wide">
    <div class="section-head reveal">
      <span class="eyebrow">Naši projekti</span>
      <h2 class="section-title">Galerija</h2>
      <p>Izbor izvedenih betonskih površin in projektov.</p>
    </div>

    <div class="gallery reveal">
      {
        images.map((img, i) => (
          <button
            class="gallery__item"
            data-index={i}
            aria-label={`Odpri sliko ${i + 1}`}
          >
            <Picture
              src={img}
              alt={`Projekt BTON ${i + 1}`}
              formats={['webp']}
              widths={i === 0 ? [600, 960, 1280] : [360, 600]}
              sizes={
                i === 0
                  ? '(max-width: 600px) 100vw, (max-width: 980px) 66vw, 50vw'
                  : '(max-width: 600px) 50vw, (max-width: 980px) 33vw, 25vw'
              }
              quality={58}
              class="gallery__img"
              loading={i < 4 ? 'eager' : 'lazy'}
            />
          </button>
        ))
      }
    </div>
  </div>
</section>

<!-- Lightbox -->
<div class="lightbox" id="lightbox" hidden aria-hidden="true">
  <button class="lightbox__close" aria-label="Zapri">&times;</button>
  <button class="lightbox__nav lightbox__prev" aria-label="Prejšnja">&#8249;</button>
  <img class="lightbox__img" id="lightbox-img" alt="" />
  <button class="lightbox__nav lightbox__next" aria-label="Naslednja">&#8250;</button>
</div>

<script
  is:inline
  define:vars={{
    full: images.map((i) => ({ src: i.src, w: i.width, h: i.height })),
  }}
>
  (() => {
    const lb = document.getElementById('lightbox');
    const lbImg = document.getElementById('lightbox-img');
    const items = document.querySelectorAll('.gallery__item');
    let current = 0;

    const open = (i) => {
      current = (i + full.length) % full.length;
      lbImg.src = full[current].src;
      lb.hidden = false;
      lb.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    };
    const close = () => {
      lb.hidden = true;
      lb.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    };

    items.forEach((it) =>
      it.addEventListener('click', () =>
        open(parseInt(it.getAttribute('data-index')))
      )
    );
    lb.querySelector('.lightbox__close').addEventListener('click', close);
    lb.querySelector('.lightbox__prev').addEventListener('click', (e) => {
      e.stopPropagation();
      open(current - 1);
    });
    lb.querySelector('.lightbox__next').addEventListener('click', (e) => {
      e.stopPropagation();
      open(current + 1);
    });
    lb.addEventListener('click', (e) => {
      if (e.target === lb) close();
    });
    document.addEventListener('keydown', (e) => {
      if (lb.hidden) return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowLeft') open(current - 1);
      if (e.key === 'ArrowRight') open(current + 1);
    });
  })();
</script>

<style>
  .gallery {
    --gallery-gap: clamp(0.6rem, 1.2vw, 1rem);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: clamp(150px, 19vw, 250px);
    gap: var(--gallery-gap);
  }

  .gallery__item {
    padding: 0;
    border-radius: var(--radius-sm);
    overflow: hidden;
    position: relative;
    background: var(--bg-soft);
  }
  /* Mosaic: 2×2 feature + two tall tiles → 11 items fill 4 rows exactly */
  .gallery__item:nth-child(1) {
    grid-column: span 2;
    grid-row: span 2;
  }
  .gallery__item:nth-child(2),
  .gallery__item:nth-child(5) {
    grid-row: span 2;
  }
  .gallery__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .gallery__item::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(20, 23, 27, 0);
    transition: background 0.35s ease;
  }
  .gallery__item:hover .gallery__img {
    transform: scale(1.07);
  }
  .gallery__item:hover::after {
    background: rgba(20, 23, 27, 0.18);
  }

  /* Tablet: 3 columns — feature 2×2 + one tall + 9 singles = 5 full rows */
  @media (max-width: 980px) {
    .gallery {
      grid-template-columns: repeat(3, 1fr);
      grid-auto-rows: clamp(140px, 26vw, 240px);
    }
    .gallery__item:nth-child(5) {
      grid-row: auto;
    }
  }
  /* Mobile: 2 columns — full-width feature + 10 singles = 6 full rows */
  @media (max-width: 600px) {
    .gallery {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: clamp(130px, 42vw, 240px);
    }
    .gallery__item:nth-child(1) {
      grid-column: 1 / -1;
      grid-row: auto;
    }
    .gallery__item:nth-child(2) {
      grid-row: auto;
    }
  }

  /* Lightbox */
  .lightbox[hidden] {
    display: none;
  }
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(15, 17, 20, 0.92);
    padding: clamp(1rem, 4vw, 3rem);
  }
  .lightbox__img {
    max-width: 100%;
    max-height: 90vh;
    border-radius: 8px;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.5);
  }
  .lightbox__close {
    position: absolute;
    top: 1rem;
    right: 1.4rem;
    font-size: 2.5rem;
    line-height: 1;
    color: #fff;
    opacity: 0.8;
  }
  .lightbox__close:hover {
    opacity: 1;
  }
  .lightbox__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 54px;
    height: 54px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
    font-size: 2rem;
    line-height: 1;
    display: grid;
    place-items: center;
    transition: background 0.25s ease;
  }
  .lightbox__nav:hover {
    background: rgba(255, 255, 255, 0.22);
  }
  .lightbox__prev {
    left: clamp(0.6rem, 2vw, 2rem);
  }
  .lightbox__next {
    right: clamp(0.6rem, 2vw, 2rem);
  }
  @media (max-width: 600px) {
    .lightbox__nav {
      width: 44px;
      height: 44px;
      font-size: 1.6rem;
    }
  }
</style>
