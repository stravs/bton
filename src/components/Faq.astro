---
import { faqs } from '../data/services';
---

<section class="section faq" id="faq">
  <div class="container">
    <div class="sec-head reveal">
      <div class="sec-head__row">
        <span class="kicker">Vprašanja</span>
        <span class="kicker">Niste našli odgovora? Pokličite nas</span>
      </div>
      <h2 class="sec-title">Pogosta vprašanja<em>.</em></h2>
    </div>

    <div class="faq__list reveal">
      {
        faqs.map((f) => (
          <details class="faq__item">
            <summary class="faq__q">
              <span class="faq__q-text">{f.q}</span>
              <svg class="faq__plus" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
                <path class="faq__plus-v" d="M8 1v14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                <path d="M1 8h14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
              </svg>
            </summary>
            <div class="faq__a">
              <p>{f.a}</p>
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  .faq__list {
    display: flex;
    flex-direction: column;
    max-width: 920px;
  }

  .faq__item {
    border-bottom: 1px solid var(--line);
  }

  .faq__q {
    display: flex;
    align-items: baseline;
    gap: clamp(1rem, 3vw, 2rem);
    padding: 1.4rem 0.25rem;
    cursor: pointer;
    list-style: none;
    font-family: var(--font-display);
    font-weight: 560;
    font-stretch: 106%;
    letter-spacing: -0.01em;
    font-size: clamp(1.05rem, 1.8vw, 1.3rem);
    color: var(--ink);
    transition: color 0.22s ease;
  }
  .faq__q::-webkit-details-marker {
    display: none;
  }
  .faq__q:hover {
    color: var(--accent);
  }

  .faq__q-text {
    flex: 1;
  }

  .faq__plus {
    flex: none;
    align-self: center;
    color: var(--muted);
  }
  .faq__plus path {
    transform-origin: center;
    transition: transform 0.3s ease;
  }
  .faq__item[open] .faq__plus-v {
    transform: rotate(90deg);
  }
  .faq__item[open] .faq__plus {
    color: var(--accent);
  }

  .faq__a {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s ease;
  }
  .faq__item[open] .faq__a {
    grid-template-rows: 1fr;
  }
  .faq__a > p {
    overflow: hidden;
    margin: 0;
    padding-left: 0.25rem;
    color: var(--body);
    max-width: 68ch;
  }
  .faq__item[open] .faq__a > p {
    padding-bottom: 1.5rem;
  }
</style>
