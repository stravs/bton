---
import FaqList from './FaqList.astro';
import { faqs } from '../data/services';
---

<section class="section faq" id="faq">
  <div class="container">
    <div class="sec-head reveal">
      <div class="sec-head__row">
        <span class="kicker">Vprašanja</span>
        <span class="kicker">Niste našli odgovora? Pokličite nas</span>
      </div>
      <h2 class="sec-title">Pogosta vprašanja<em>.</em></h2>
    </div>

    <FaqList faqs={faqs} />

    <p class="faq__more reveal">
      Se odločate med materiali? Preberite podrobno primerjavo:
      <a href="/tiskan-beton-ali-tlakovci">Tiskan beton ali tlakovci?</a>
    </p>
  </div>
</section>

<style>
  .faq__more {
    margin-top: 1.6rem;
    color: var(--body);
  }
  .faq__more a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .faq__more a:hover {
    color: var(--accent-deep);
  }
</style>

<script
  type="application/ld+json"
  set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  })}
/>
