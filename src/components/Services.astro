---
import { Picture } from 'astro:assets';
import { services } from '../data/services';
---

<section class="section" id="storitve">
  <div class="container">
    <div class="sec-head reveal">
      <div class="sec-head__row">
        <span class="kicker"><b>01</b> / Storitve</span>
        <span class="kicker">Ogled in ponudba — brezplačno</span>
      </div>
      <h2 class="sec-title">Štiri obdelave, en material<em>.</em></h2>
      <p class="sec-lead">
        Urejate teraso, dvorišče ali dovoz? Izberite obdelavo, ki ustreza
        vašemu domu — če niste prepričani, vam z veseljem svetujemo pri izbiri.
      </p>
    </div>

    <div class="svc-list">
      {
        services.map((s, i) => (
          <a href={`/storitve/${s.id}`} class="svc-row reveal">
            <span class="svc-row__num" aria-hidden="true">0{i + 1}</span>
            <span class="svc-row__body">
              <h3 class="svc-row__title">{s.title}</h3>
              <p class="svc-row__text">{s.summary}</p>
              <span class="svc-row__tags">
                {s.idealFor.slice(0, 3).map((t) => (
                  <span>{t}</span>
                ))}
              </span>
              <span class="svc-row__more">
                Več o storitvi
                <svg width="16" height="12" viewBox="0 0 16 12" aria-hidden="true">
                  <path d="M1 6h13M9 1l5 5-5 5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
            </span>
            <span class="svc-row__media">
              <Picture
                src={s.photo}
                alt={s.alt}
                formats={['avif', 'webp']}
                widths={[400, 700, 1000]}
                sizes="(max-width: 760px) 100vw, 38vw"
                quality={58}
                class="svc-row__img"
                loading="lazy"
              />
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .svc-list {
    display: flex;
    flex-direction: column;
  }

  .svc-row {
    display: grid;
    grid-template-columns: 4rem 1fr minmax(280px, 38%);
    gap: clamp(1.25rem, 3vw, 3rem);
    align-items: center;
    padding-block: clamp(1.75rem, 3.5vw, 2.75rem);
    border-top: 1px solid var(--line);
  }
  .svc-row:last-child {
    border-bottom: 1px solid var(--line);
  }

  .svc-row__num {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    color: var(--muted);
    align-self: start;
    padding-top: 0.55rem;
    transition: color 0.25s ease;
  }

  .svc-row__title {
    font-size: clamp(1.7rem, 3.2vw, 2.5rem);
    transition: color 0.25s ease;
  }

  .svc-row__text {
    margin-top: 0.8rem;
    max-width: 52ch;
    color: var(--body);
  }

  .svc-row__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 1.1rem;
  }
  .svc-row__tags span {
    font-family: var(--font-label);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    border: 1px solid var(--line);
    padding: 0.3rem 0.7rem;
  }

  .svc-row__more {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin-top: 1.4rem;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 0.74rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink);
  }
  .svc-row__more svg {
    transition: transform 0.3s ease;
  }

  .svc-row__media {
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: var(--paper-2);
  }
  .svc-row__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .svc-row:hover .svc-row__num,
  .svc-row:hover .svc-row__title {
    color: var(--accent);
  }
  .svc-row:hover .svc-row__more svg {
    transform: translateX(5px);
  }
  .svc-row:hover .svc-row__img {
    transform: scale(1.05);
  }

  @media (max-width: 760px) {
    .svc-row {
      grid-template-columns: 1fr;
      gap: 1.1rem;
    }
    .svc-row__num {
      padding-top: 0;
    }
    .svc-row__media {
      order: -1;
      aspect-ratio: 16 / 9;
    }
  }
</style>
