---
import { Image } from 'astro:assets';
import logoWhite from '../assets/images/logo-white.png';
import logoDark from '../assets/images/logo-dark.png';
import { services } from '../data/services';

interface Props {
  /** Force the solid (light) header — use on pages without a dark hero. */
  solid?: boolean;
}
const { solid = false } = Astro.props;

const nav = [
  { label: 'Storitve', href: '/#storitve', children: services },
  { label: 'Vprašanja', href: '/#faq' },
  { label: 'Projekti', href: '/#galerija' },
  { label: 'Kontakt', href: '/#kontakt' },
];
---

<header
  class="header"
  id="site-header"
  data-state={solid ? 'scrolled' : 'top'}
  data-solid={String(solid)}
>
  <div class="container header__inner">
    <a href="/" class="header__logo" aria-label="BTON — domov">
      <Image src={logoWhite} alt="BTON" class="logo logo--white" widths={[120, 240]} sizes="120px" />
      <Image src={logoDark} alt="BTON" class="logo logo--dark" widths={[120, 240]} sizes="120px" />
    </a>

    <nav class="nav" aria-label="Glavna navigacija">
      <ul class="nav__list">
        {
          nav.map((item, i) => (
            <li class={item.children ? 'nav__item nav__item--has-menu' : 'nav__item'}>
              <a href={item.href} class="nav__link">
                <span class="nav__num" aria-hidden="true">0{i + 1}</span>
                {item.label}
              </a>
              {item.children && (
                <div class="nav__dropdown">
                  <ul>
                    {item.children.map((s, j) => (
                      <li>
                        <a href={`/storitve/${s.id}`}>
                          <span class="nav__num" aria-hidden="true">0{j + 1}</span>
                          {s.title}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </li>
          ))
        }
      </ul>
    </nav>

    <a href="/#kontakt" class="btn header__cta">Povpraševanje</a>

    <button class="burger" id="burger" aria-label="Odpri meni" aria-expanded="false" aria-controls="mobile-menu">
      <span></span><span></span>
    </button>
  </div>
</header>

<!-- Mobile menu -->
<div class="mobile" id="mobile-menu" hidden>
  <nav aria-label="Mobilna navigacija">
    <ul>
      {
        nav.map((item, i) => (
          <li>
            <a href={item.href} class="mobile__link" data-close>
              <span class="mobile__num" aria-hidden="true">0{i + 1}</span>
              {item.label}
            </a>
            {item.children && (
              <ul class="mobile__sub">
                {item.children.map((s) => (
                  <li>
                    <a href={`/storitve/${s.id}`} data-close>
                      {s.title}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))
      }
    </ul>
    <a href="/#kontakt" class="btn mobile__cta" data-close>Pošlji povpraševanje</a>
    <div class="mobile__meta">
      <a href="tel:+38630638685">+386 30 638 685</a>
      <a href="mailto:info@bton.si">info@bton.si</a>
    </div>
  </nav>
</div>

<style>
  .header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 100;
    height: var(--header-h);
    display: flex;
    align-items: center;
    border-bottom: 1px solid transparent;
    transition: background 0.3s ease, border-color 0.3s ease;
  }

  .header__inner {
    display: flex;
    align-items: center;
    gap: 1.75rem;
  }

  .header__logo {
    display: inline-flex;
    align-items: center;
    margin-right: auto;
  }

  .logo {
    width: 48px;
    height: auto;
    transition: opacity 0.3s ease;
  }
  .logo--dark {
    position: absolute;
    opacity: 0;
  }

  /* Scrolled state */
  .header[data-state='scrolled'] {
    background: rgba(241, 239, 234, 0.92);
    backdrop-filter: saturate(160%) blur(10px);
    border-bottom-color: var(--line);
  }
  .header[data-state='scrolled'] .logo--white,
  :global(body.menu-open) .logo--white {
    opacity: 0;
  }
  .header[data-state='scrolled'] .logo--dark,
  :global(body.menu-open) .logo--dark {
    opacity: 1;
  }

  /* Nav */
  .nav__list {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nav__item {
    position: relative;
  }

  .nav__link {
    display: inline-flex;
    align-items: baseline;
    gap: 0.45rem;
    padding: 0.6rem 0.85rem;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 0.76rem;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.92);
    transition: color 0.22s ease;
  }
  .nav__num {
    font-size: 0.62rem;
    opacity: 0.55;
  }
  .nav__link:hover {
    color: #fff;
    text-decoration: underline;
    text-underline-offset: 5px;
    text-decoration-thickness: 1px;
  }
  .header[data-state='scrolled'] .nav__link {
    color: var(--ink);
  }
  .header[data-state='scrolled'] .nav__link:hover {
    color: var(--accent);
  }

  /* Dropdown */
  .nav__dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 260px;
    background: var(--paper);
    border: 1px solid var(--line);
    padding: 0.4rem 0;
    opacity: 0;
    visibility: hidden;
    transform: translateY(6px);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s;
  }
  .nav__item--has-menu:hover .nav__dropdown,
  .nav__item--has-menu:focus-within .nav__dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .nav__dropdown li + li {
    border-top: 1px solid var(--line-soft);
  }
  .nav__dropdown a {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    padding: 0.75rem 1.1rem;
    font-size: 0.92rem;
    color: var(--ink-soft);
    transition: background 0.2s ease, color 0.2s ease;
  }
  .nav__dropdown a .nav__num {
    font-family: var(--font-label);
    font-size: 0.62rem;
    color: var(--muted);
  }
  .nav__dropdown a:hover {
    background: var(--ink);
    color: var(--paper);
  }
  .nav__dropdown a:hover .nav__num {
    color: var(--accent);
  }

  .header__cta {
    padding: 0.6rem 1.2rem;
    font-size: 0.88rem;
  }
  .header[data-state='top'] .header__cta {
    background: transparent;
    border-color: rgba(255, 255, 255, 0.5);
    color: #fff;
  }
  .header[data-state='top'] .header__cta:hover {
    background: var(--paper);
    border-color: var(--paper);
    color: var(--ink);
  }

  /* Burger — two lines, collapses to × */
  .burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 7px;
    width: 42px;
    height: 42px;
    padding: 8px;
  }
  .burger span {
    width: 26px;
    height: 2px;
    background: #fff;
    transition: transform 0.3s ease, background 0.3s ease;
  }
  .header[data-state='scrolled'] .burger span,
  body.menu-open .burger span {
    background: var(--ink);
  }
  body.menu-open .burger span:nth-child(1) {
    transform: translateY(4.5px) rotate(45deg);
  }
  body.menu-open .burger span:nth-child(2) {
    transform: translateY(-4.5px) rotate(-45deg);
  }

  /* Mobile menu panel */
  .mobile {
    position: fixed;
    inset: 0;
    z-index: 99;
    background: var(--paper);
    padding: calc(var(--header-h) + 1.5rem) var(--gutter) 2rem;
    overflow-y: auto;
    opacity: 0;
    transform: translateY(-8px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .mobile.is-open {
    opacity: 1;
    transform: none;
  }
  .mobile__link {
    display: flex;
    align-items: baseline;
    gap: 0.9rem;
    font-family: var(--font-display);
    font-weight: 640;
    font-stretch: 112%;
    letter-spacing: -0.02em;
    font-size: 1.9rem;
    color: var(--ink);
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--line);
  }
  .mobile__num {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: var(--accent);
  }
  .mobile__sub {
    padding: 0.5rem 0 0.9rem 2.1rem;
    border-bottom: 1px solid var(--line);
  }
  .mobile__sub a {
    display: block;
    padding: 0.4rem 0;
    color: var(--body);
    font-size: 1rem;
  }
  .mobile__cta {
    width: 100%;
    margin-top: 1.75rem;
  }
  .mobile__meta {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-top: 1.75rem;
    font-family: var(--font-label);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: var(--muted);
  }

  @media (max-width: 960px) {
    .nav,
    .header__cta {
      display: none;
    }
    .burger {
      display: flex;
    }
  }
</style>

<script>
  const header = document.getElementById('site-header')!;
  const solid = header.dataset.solid === 'true';
  const onScroll = () => {
    header.dataset.state = solid || window.scrollY > 40 ? 'scrolled' : 'top';
  };
  onScroll();
  if (!solid) window.addEventListener('scroll', onScroll, { passive: true });

  const burger = document.getElementById('burger')!;
  const menu = document.getElementById('mobile-menu')!;
  const setMenu = (open: boolean) => {
    document.body.classList.toggle('menu-open', open);
    burger.setAttribute('aria-expanded', String(open));
    if (open) {
      menu.hidden = false;
      requestAnimationFrame(() => menu.classList.add('is-open'));
      document.body.style.overflow = 'hidden';
    } else {
      menu.classList.remove('is-open');
      document.body.style.overflow = '';
      setTimeout(() => (menu.hidden = true), 300);
    }
  };
  burger.addEventListener('click', () =>
    setMenu(burger.getAttribute('aria-expanded') !== 'true')
  );
  menu.querySelectorAll('[data-close]').forEach((a) =>
    a.addEventListener('click', () => setMenu(false))
  );
</script>
