---
const items = [
  {
    title: 'Osebni pristop',
    text: 'Od prvega ogleda do predaje sodelujete neposredno z izvajalcem — brez posrednikov in klicnih centrov.',
  },
  {
    title: 'Kakovost, ki traja',
    text: 'Uporabljamo preverjene materiale in vsako površino zaščitimo s premazi, da vam dobro služi dolga leta.',
  },
  {
    title: 'Jasen dogovor',
    text: 'Pred začetkom del natančno veste, kaj bo narejeno, kdaj in za kakšno ceno. Dogovore držimo.',
  },
];
---

<section class="section section--dark why">
  <div class="container">
    <div class="sec-head reveal">
      <div class="sec-head__row">
        <span class="kicker"><b>02</b> / Zakaj BTON</span>
        <span class="kicker">Bled · Maribor · vsa Slovenija</span>
      </div>
      <h2 class="sec-title">
        Majhna ekipa. Neposreden dogovor. Površine, ki trajajo<em>.</em>
      </h2>
    </div>

    <div class="why__grid">
      {
        items.map((it, i) => (
          <div class="why__item reveal" style={`transition-delay:${i * 90}ms`}>
            <span class="why__num" aria-hidden="true">0{i + 1}</span>
            <h3 class="why__title">{it.title}</h3>
            <p class="why__text">{it.text}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .why .sec-title {
    max-width: 24ch;
  }

  .why__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.5rem, 3.5vw, 3rem);
  }

  .why__item {
    border-top: 1px solid var(--line-dark);
    padding-top: 1.4rem;
  }

  .why__num {
    display: block;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    color: var(--accent-on-dark);
    margin-bottom: 1.6rem;
  }

  .why__title {
    color: var(--on-dark-strong);
    font-size: 1.35rem;
    margin-bottom: 0.7rem;
  }

  .why__text {
    color: var(--on-dark);
    max-width: 34ch;
    font-size: 0.97rem;
  }

  @media (max-width: 760px) {
    .why__grid {
      grid-template-columns: 1fr;
    }
    .why__num {
      margin-bottom: 1rem;
    }
  }
</style>
