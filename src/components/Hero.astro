---
import { getImage } from 'astro:assets';
import heroPosterSrc from '../assets/images/hero-poster.jpg';

// Optimize the video poster (raw JPG was ~412 KiB) down to a small webp.
const heroPoster = await getImage({
  src: heroPosterSrc,
  format: 'webp',
  width: 1280,
  quality: 55,
});
---

<section class="hero" id="domov">
  <video
    class="hero__video"
    autoplay
    muted
    loop
    playsinline
    webkit-playsinline
    preload="auto"
    poster={heroPoster.src}
    aria-hidden="true"
  >
    <source src="/videos/hero.mp4" type="video/mp4" />
  </video>
  <div class="hero__overlay"></div>

  <div class="container hero__content">
    <!-- The small kicker carries the keyword-bearing H1; the slogan below
         stays the visual headline. -->
    <h1 class="hero__kicker">Betonske površine — tiskan, štokan, metličen in brušen beton po vsej Sloveniji</h1>
    <p class="hero__title">Domišljiji dajemo obliko<span>.</span></p>
    <p class="hero__lead">
      Urejate dvorišče, teraso ali pot okoli hiše? Pomagamo vam ustvariti
      betonsko površino, ki je lepa, uporabna in trajna — od prvega opaža do
      zadnjega premaza.
    </p>
    <div class="hero__actions">
      <a href="#storitve" class="btn btn--light">Razišči ponudbo</a>
      <a href="#kontakt" class="btn btn--outline-light">Pošlji povpraševanje</a>
    </div>
  </div>

  <div class="hero__meta">
    <div class="container hero__meta-inner">
      <span>Bled · Maribor · vsa Slovenija</span>
      <a href="tel:+38630638685">+386 30 638 685</a>
      <span class="hero__meta-note">Ogled in ponudba — brezplačno</span>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const video = document.querySelector('.hero__video');
    if (!(video instanceof HTMLVideoElement)) return;

    const playHeroVideo = () => {
      video.muted = true;
      video.defaultMuted = true;
      video.playsInline = true;
      video.setAttribute('muted', '');
      video.setAttribute('playsinline', '');
      video.setAttribute('webkit-playsinline', '');

      const attempt = video.play();
      if (attempt?.catch) attempt.catch(() => {});
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', playHeroVideo, { once: true });
    } else {
      playHeroVideo();
    }

    window.addEventListener('pageshow', playHeroVideo);
    document.addEventListener('visibilitychange', () => {
      if (!document.hidden) playHeroVideo();
    });
    document.addEventListener('touchstart', playHeroVideo, { once: true, passive: true });
  })();
</script>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    color: #fff;
    overflow: hidden;
    z-index: 0;
  }

  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(180deg, rgba(19, 17, 16, 0.45) 0%, rgba(19, 17, 16, 0.15) 40%, rgba(19, 17, 16, 0.78) 100%),
      linear-gradient(75deg, rgba(19, 17, 16, 0.55) 0%, rgba(19, 17, 16, 0) 60%);
  }

  .hero__content {
    position: relative;
    z-index: 2;
    padding-top: calc(var(--header-h) + 2rem);
    padding-bottom: clamp(2.5rem, 6vh, 5rem);
  }

  .hero__kicker {
    max-width: 44ch;
    font-family: var(--font-label);
    font-weight: 600;
    font-stretch: 100%;
    font-size: 0.75rem;
    line-height: 1.6;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.75);
    padding-bottom: 1.1rem;
    margin-bottom: 1.4rem;
    position: relative;
  }
  .hero__kicker::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 56px;
    height: 1px;
    background: var(--accent);
  }

  .hero__title {
    color: #fff;
    font-weight: 680;
    font-stretch: 114%;
    font-size: clamp(2.6rem, 7.2vw, 6rem);
    line-height: 0.98;
    letter-spacing: -0.025em;
    max-width: 14ch;
    text-wrap: balance;
  }
  .hero__title span {
    color: var(--accent);
  }

  .hero__lead {
    margin-top: 1.6rem;
    max-width: 54ch;
    font-size: clamp(1rem, 1.5vw, 1.13rem);
    color: rgba(255, 255, 255, 0.86);
  }

  .hero__actions {
    margin-top: 2.2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
  }

  .hero__meta {
    position: relative;
    z-index: 2;
    border-top: 1px solid rgba(255, 255, 255, 0.22);
  }
  .hero__meta-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem 2rem;
    padding-block: 1.05rem;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.65);
  }
  .hero__meta-inner a:hover {
    color: #fff;
  }

  @media (max-width: 640px) {
    .hero__meta-note {
      display: none;
    }

    .hero__title {
      font-size: clamp(2.3rem, 11vw, 3rem);
    }

    .hero__lead {
      margin-top: 1.2rem;
      font-size: 0.95rem;
    }

    .hero__actions {
      margin-top: 1.6rem;
      gap: 0.7rem;
    }

    .hero__actions .btn {
      padding: 0.8rem 1.3rem;
      font-size: 0.88rem;
    }
  }
</style>
