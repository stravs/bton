---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  photos: { src: ImageMetadata; alt: string }[];
}
const { photos } = Astro.props;
---

{
  photos.length > 0 && (
    <section class="section section--soft svc-gallery" aria-label="Primeri izvedb">
      <div class="container">
        <div class="section-head reveal">
          <span class="eyebrow">Iz naših projektov</span>
          <h2 class="section-title">Primeri izvedb</h2>
        </div>
        <div
          class={`svc-gallery__grid reveal ${photos.length === 2 ? 'svc-gallery__grid--two' : ''}`}
        >
          {photos.map((p, i) => (
            <button class="svc-gallery__item" data-index={i} aria-label={`Odpri sliko: ${p.alt}`}>
              <Picture
                src={p.src}
                alt={p.alt}
                formats={['avif', 'webp']}
                widths={[400, 700, 1000]}
                sizes="(max-width: 700px) 100vw, 33vw"
                quality={58}
                class="svc-gallery__img"
              />
            </button>
          ))}
        </div>
      </div>
    </section>

    <div class="lightbox" id="svc-lightbox" hidden aria-hidden="true">
      <button class="lightbox__close" aria-label="Zapri">&times;</button>
      <button class="lightbox__nav lightbox__prev" aria-label="Prejšnja">&#8249;</button>
      <img class="lightbox__img" id="svc-lightbox-img" alt="" />
      <button class="lightbox__nav lightbox__next" aria-label="Naslednja">&#8250;</button>
    </div>
  )
}

<script
  is:inline
  define:vars={{
    full: photos.map((p) => ({ src: p.src.src, alt: p.alt })),
  }}
>
  (() => {
    if (!full.length) return;
    const lb = document.getElementById('svc-lightbox');
    const lbImg = document.getElementById('svc-lightbox-img');
    const items = document.querySelectorAll('.svc-gallery__item');
    let current = 0;

    const open = (i) => {
      current = (i + full.length) % full.length;
      lbImg.src = full[current].src;
      lbImg.alt = full[current].alt;
      lb.hidden = false;
      lb.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    };
    const close = () => {
      lb.hidden = true;
      lb.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    };

    items.forEach((it) =>
      it.addEventListener('click', () => open(parseInt(it.getAttribute('data-index'))))
    );
    lb.querySelector('.lightbox__close').addEventListener('click', close);
    lb.querySelector('.lightbox__prev').addEventListener('click', (e) => {
      e.stopPropagation();
      open(current - 1);
    });
    lb.querySelector('.lightbox__next').addEventListener('click', (e) => {
      e.stopPropagation();
      open(current + 1);
    });
    lb.addEventListener('click', (e) => {
      if (e.target === lb) close();
    });
    document.addEventListener('keydown', (e) => {
      if (lb.hidden) return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowLeft') open(current - 1);
      if (e.key === 'ArrowRight') open(current + 1);
    });
  })();
</script>

<style>
  .svc-gallery__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(0.6rem, 1.2vw, 1rem);
  }
  .svc-gallery__grid--two {
    grid-template-columns: repeat(2, 1fr);
    max-width: 900px;
    margin-inline: auto;
  }

  .svc-gallery__item {
    padding: 0;
    border-radius: var(--radius-sm);
    overflow: hidden;
    position: relative;
    aspect-ratio: 4 / 3;
    background: var(--bg-softer);
  }
  .svc-gallery__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .svc-gallery__item::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(20, 23, 27, 0);
    transition: background 0.35s ease;
  }
  .svc-gallery__item:hover .svc-gallery__img {
    transform: scale(1.07);
  }
  .svc-gallery__item:hover::after {
    background: rgba(20, 23, 27, 0.18);
  }

  @media (max-width: 700px) {
    .svc-gallery__grid,
    .svc-gallery__grid--two {
      grid-template-columns: 1fr;
    }
  }

  /* Lightbox */
  .lightbox[hidden] {
    display: none;
  }
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(15, 17, 20, 0.92);
    padding: clamp(1rem, 4vw, 3rem);
  }
  .lightbox__img {
    max-width: 100%;
    max-height: 90vh;
    border-radius: 8px;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.5);
  }
  .lightbox__close {
    position: absolute;
    top: 1rem;
    right: 1.4rem;
    font-size: 2.5rem;
    line-height: 1;
    color: #fff;
    opacity: 0.8;
  }
  .lightbox__close:hover {
    opacity: 1;
  }
  .lightbox__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 54px;
    height: 54px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
    font-size: 2rem;
    line-height: 1;
    display: grid;
    place-items: center;
    transition: background 0.25s ease;
  }
  .lightbox__nav:hover {
    background: rgba(255, 255, 255, 0.22);
  }
  .lightbox__prev {
    left: clamp(0.6rem, 2vw, 2rem);
  }
  .lightbox__next {
    right: clamp(0.6rem, 2vw, 2rem);
  }
  @media (max-width: 600px) {
    .lightbox__nav {
      width: 44px;
      height: 44px;
      font-size: 1.6rem;
    }
  }
</style>
