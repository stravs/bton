---
import { services } from '../data/services';

const phoneDisplay = '+386 30 638 685';
const phoneHref = 'tel:+38630638685';
const email = 'info@bton.si';
---

<section class="section contact" id="kontakt">
  <div class="container">
    <div class="section-head reveal" style="text-align:center">
      <span class="eyebrow">Kontakt</span>
      <h2 class="section-title">Z veseljem smo vam na voljo</h2>
      <p>
        Za svetovanje smo vam na voljo vsak delovnik med 8. in 19. uro na
        telefonski številki <a href={phoneHref} class="inline-link">{phoneDisplay}</a>.
        Kontaktirate nas lahko tudi preko spletnega obrazca ali nam pišete na
        <a href={`mailto:${email}`} class="inline-link">{email}</a>.
      </p>
    </div>

    <div class="contact__grid">
      <!-- Info column -->
      <div class="contact__info reveal">
        <ul class="contact__list">
          <li>
            <span class="contact__ic" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2 4.2 2 2 0 0 1 4 2h3a2 2 0 0 1 2 1.7c.1 1 .4 1.9.7 2.8a2 2 0 0 1-.5 2.1L8 9.9a16 16 0 0 0 6 6l1.3-1.3a2 2 0 0 1 2.1-.4c.9.3 1.8.6 2.8.7a2 2 0 0 1 1.8 2Z"/></svg>
            </span>
            <div>
              <span class="contact__label">Telefonska številka</span>
              <a href={phoneHref}>{phoneDisplay}</a>
            </div>
          </li>
          <li>
            <span class="contact__ic" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 6 10-6"/></svg>
            </span>
            <div>
              <span class="contact__label">Email</span>
              <a href={`mailto:${email}`}>{email}</a>
            </div>
          </li>
          <li>
            <span class="contact__ic" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            </span>
            <div>
              <span class="contact__label">Lokacija</span>
              <span>Kajuhova 19, 4260 Bled, Slovenija</span>
            </div>
          </li>
        </ul>

        <div class="contact__company">
          <p>BTON, nizke gradnje, Dejan Hodžić, s.p.</p>
          <p>Davčna številka: 55681379</p>
          <p>Matična številka: 9084258000</p>
        </div>

        <div class="contact__social">
          <a href="https://www.facebook.com/" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M14 9h3l.5-3H14V4.5c0-.9.3-1.5 1.6-1.5H17V.2A21 21 0 0 0 14.7 0C12.3 0 10.7 1.4 10.7 4.1V6H8v3h2.7v9H14V9Z"/></svg>
          </a>
        </div>
      </div>

      <!-- Form column -->
      <div class="contact__form-wrap reveal">
        <h3 class="contact__form-title">Pošljite nam sporočilo</h3>
        <form class="contact__form" id="contact-form" novalidate>
          <div class="field">
            <label for="name">Ime in priimek</label>
            <input type="text" id="name" name="name" autocomplete="name" required />
          </div>
          <div class="field-row">
            <div class="field">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" autocomplete="email" required />
            </div>
            <div class="field">
              <label for="phone">Telefonska številka</label>
              <input type="tel" id="phone" name="phone" autocomplete="tel" />
            </div>
          </div>
          <div class="field-row">
            <div class="field">
              <label for="service">Storitev</label>
              <select id="service" name="service">
                <option value="" disabled selected>Prosimo, izberite storitev</option>
                {services.map((s) => <option value={s.title}>{s.title}</option>)}
              </select>
            </div>
            <div class="field">
              <label for="location">Lokacija projekta</label>
              <input type="text" id="location" name="location" />
            </div>
          </div>
          <div class="field">
            <label for="message">Vaše sporočilo</label>
            <textarea id="message" name="message" rows="4"></textarea>
          </div>
          <label class="consent">
            <input type="checkbox" name="consent" required />
            <span>Soglašam z obdelavo osebnih podatkov za namen oddaje povpraševanja. <span class="req">*</span></span>
          </label>
          <button type="submit" class="btn contact__submit">Pošlji sporočilo</button>
          <p class="form-note" id="form-note" role="status" aria-live="polite"></p>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .inline-link {
    color: var(--ink);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .contact__grid {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: start;
  }

  .contact__list {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
  }
  .contact__list li {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }
  .contact__ic {
    flex: none;
    display: grid;
    place-items: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--bg-soft);
    color: var(--ink);
  }
  .contact__ic svg {
    width: 22px;
    height: 22px;
  }
  .contact__label {
    display: block;
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--ink);
    font-size: 1.02rem;
    margin-bottom: 0.15rem;
  }
  .contact__list a:hover {
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .contact__company {
    margin-top: 2.2rem;
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.8;
  }

  .contact__social {
    margin-top: 1.8rem;
  }
  .contact__social a {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--ink);
    color: #fff;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }
  .contact__social a:hover {
    transform: translateY(-3px);
    opacity: 0.9;
  }
  .contact__social svg {
    width: 20px;
    height: 20px;
  }

  /* Form */
  .contact__form-wrap {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: clamp(1.6rem, 3vw, 2.6rem);
    box-shadow: var(--shadow-md);
  }
  .contact__form-title {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .contact__form {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }
  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.1rem;
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .field label {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--muted);
  }
  .field input,
  .field select,
  .field textarea {
    width: 100%;
    padding: 0.8rem 0.95rem;
    background: var(--bg-soft);
    border: 1px solid transparent;
    border-radius: var(--radius-sm);
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    outline: none;
    background: #fff;
    border-color: var(--line-strong);
  }
  .field textarea {
    resize: vertical;
  }

  .consent {
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
    font-size: 0.88rem;
    color: var(--body);
  }
  .consent input {
    margin-top: 0.25rem;
    width: 18px;
    height: 18px;
    flex: none;
    accent-color: var(--ink);
  }
  .req {
    color: #c0392b;
  }

  .contact__submit {
    width: 100%;
    margin-top: 0.4rem;
  }

  .form-note {
    font-size: 0.9rem;
    text-align: center;
    min-height: 1.2em;
  }
  .form-note.ok {
    color: #2e7d32;
  }
  .form-note.err {
    color: #c0392b;
  }

  @media (max-width: 900px) {
    .contact__grid {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 520px) {
    .field-row {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const note = document.getElementById('form-note')!;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(form);

    if (!(data.get('name') as string)?.trim() || !(data.get('email') as string)?.trim()) {
      note.textContent = 'Prosimo, izpolnite ime in email.';
      note.className = 'form-note err';
      return;
    }
    if (!form.querySelector<HTMLInputElement>('[name="consent"]')?.checked) {
      note.textContent = 'Prosimo, potrdite soglasje za obdelavo podatkov.';
      note.className = 'form-note err';
      return;
    }

    const body = [
      `Ime in priimek: ${data.get('name') || ''}`,
      `Email: ${data.get('email') || ''}`,
      `Telefon: ${data.get('phone') || ''}`,
      `Storitev: ${data.get('service') || ''}`,
      `Lokacija projekta: ${data.get('location') || ''}`,
      '',
      `${data.get('message') || ''}`,
    ].join('\n');

    const subject = `Povpraševanje${data.get('service') ? ' – ' + data.get('service') : ''}`;
    window.location.href = `mailto:info@bton.si?subject=${encodeURIComponent(
      subject
    )}&body=${encodeURIComponent(body)}`;

    note.textContent = 'Odpiramo vaš e-poštni program za oddajo povpraševanja.';
    note.className = 'form-note ok';
  });
</script>
