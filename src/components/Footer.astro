---
const year = new Date().getFullYear();
const nav = [
  { label: 'Domov', href: '/#domov' },
  { label: 'Storitve', href: '/#storitve' },
  { label: 'Vprašanja', href: '/#faq' },
  { label: 'Projekti', href: '/#galerija' },
  { label: 'Kontakt', href: '/#kontakt' },
];
---

<footer class="footer">
  <div class="container">
    <div class="footer__top">
      <div class="footer__brand">
        <p>
          Smo manjša ekipa z Bleda in Maribora, ki ureja betonske površine za
          domove in manjša podjetja po vsej Sloveniji. Vsak projekt — velik ali
          majhen — izpeljemo natančno, po dogovoru in brez komplikacij.
        </p>
      </div>

      <nav class="footer__nav" aria-label="Noga navigacija">
        <h4>Navigacija</h4>
        <ul>
          {nav.map((n) => <li><a href={n.href}>{n.label}</a></li>)}
        </ul>
      </nav>

      <div class="footer__contact">
        <h4>Kontakt</h4>
        <ul>
          <li><a href="tel:+38630638685">+386 30 638 685</a></li>
          <li><a href="mailto:info@bton.si">info@bton.si</a></li>
          <li>Kajuhova 19, 4260 Bled, Slovenija</li>
          <li>
            <a href="https://www.facebook.com/bton.si" target="_blank" rel="noopener noreferrer">
              Facebook
            </a>
          </li>
        </ul>
      </div>
    </div>

    <p class="footer__wordmark" aria-hidden="true">BTON</p>

    <div class="footer__bottom">
      <p>{year} © BTON, nizke gradnje, Dejan Hodžić, s.p. Vse pravice pridržane.</p>
      <div class="footer__legal">
        <a href="/politika-zasebnosti">Politika zasebnosti</a>
        <a href="/pogoji-uporabe">Pogoji uporabe</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--dark-2);
    color: var(--on-dark);
    padding-top: clamp(3.5rem, 7vw, 6rem);
    overflow: hidden;
  }

  .footer__top {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }

  .footer__brand p {
    max-width: 40ch;
    font-size: 0.95rem;
    line-height: 1.8;
  }

  .footer h4 {
    color: var(--on-dark-strong);
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: 1.2rem;
  }

  .footer__nav ul,
  .footer__contact ul {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    font-size: 0.95rem;
  }
  .footer__nav a:hover,
  .footer__contact a:hover {
    color: var(--accent-on-dark);
  }

  /* Oversized wordmark set into the footer like stamped concrete */
  .footer__wordmark {
    font-family: var(--font-display);
    font-weight: 700;
    font-stretch: 125%;
    letter-spacing: -0.02em;
    line-height: 0.78;
    font-size: clamp(5rem, 22vw, 20rem);
    text-align: center;
    color: rgba(241, 239, 234, 0.07);
    user-select: none;
    transform: translateY(0.06em);
  }

  .footer__bottom {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem 1.5rem;
    justify-content: space-between;
    align-items: center;
    padding-block: 1.4rem;
    border-top: 1px solid var(--line-dark);
    font-family: var(--font-label);
    font-size: 0.72rem;
    letter-spacing: 0.03em;
    color: rgba(241, 239, 234, 0.5);
  }
  .footer__legal {
    display: flex;
    gap: 1.5rem;
  }
  .footer__legal a:hover {
    color: var(--on-dark-strong);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (max-width: 760px) {
    .footer__top {
      grid-template-columns: 1fr;
      gap: 2.2rem;
    }
    .footer__bottom {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
