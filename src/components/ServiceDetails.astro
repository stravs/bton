---
import { Picture } from 'astro:assets';
import texture from '../assets/images/concrete-texture.jpeg';
import { services } from '../data/services';
---

<section class="details" aria-label="Podrobnosti storitev">
  {
    services.map((s) => (
      <>
        <div class="details__band" role="presentation">
          <Picture
            src={texture}
            alt=""
            formats={['avif', 'webp']}
            widths={[768, 1280, 1920]}
            sizes="100vw"
            quality={58}
            class="details__band-img"
          />
        </div>

        <article class="detail" id={s.id}>
          <div class={`container detail__inner ${s.imageSide === 'right' ? 'detail__inner--reverse' : ''}`}>
            <div class="detail__media reveal">
              <Picture
                src={s.photo}
                alt={s.alt}
                formats={['avif', 'webp']}
                widths={[480, 768, 1024]}
                sizes="(max-width: 900px) 100vw, 48vw"
                quality={58}
                class="detail__img"
              />
            </div>
            <div class="detail__body reveal">
              <span class="eyebrow">Storitev</span>
              <h3 class="detail__title">{s.title}</h3>
              {s.detail.map((p) => (
                <p>{p}</p>
              ))}
              {s.cta && (
                <a href="https://www.calameo.com/books/005075689eff9f844f976" class="btn btn--ghost detail__cta" target="_blank" rel="noopener noreferrer">
                  {s.cta.label}
                </a>
              )}
            </div>
          </div>
        </article>
      </>
    ))
  }
</section>

<style>
  .details__band {
    height: clamp(60px, 18vw, 120px);
    overflow: hidden;
  }
  .details__band-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .detail {
    padding-block: clamp(3.5rem, 7vw, 6rem);
  }

  .detail__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: clamp(2rem, 5vw, 4.5rem);
  }

  .detail__media {
    position: relative;
  }
  .detail__img {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--radius);
    box-shadow: var(--shadow-md);
  }

  .detail__title {
    font-size: clamp(1.8rem, 3.4vw, 2.6rem);
    font-weight: 800;
    margin: 0.5rem 0 1.2rem;
  }

  .detail__body p {
    color: var(--body);
    margin-bottom: 1rem;
  }
  .detail__body p:last-of-type {
    margin-bottom: 0;
  }

  .detail__cta {
    margin-top: 1.6rem;
  }

  /* reverse = image on the right */
  .detail__inner--reverse .detail__media {
    order: 2;
  }

  @media (max-width: 900px) {
    .detail__inner,
    .detail__inner--reverse {
      grid-template-columns: 1fr;
    }
    .detail__inner--reverse .detail__media {
      order: 0;
    }
  }
</style>
