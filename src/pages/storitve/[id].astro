---
import { Image, Picture } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ServiceGallery from '../../components/ServiceGallery.astro';
import texture from '../../assets/images/concrete-texture.jpeg';
import { services } from '../../data/services';

export function getStaticPaths() {
  return services.map((service) => ({
    params: { id: service.id },
    props: { service },
  }));
}

const { service } = Astro.props;
const others = services.filter((s) => s.id !== service.id);

const phoneDisplay = '+386 30 638 685';
const phoneHref = 'tel:+38630638685';
---

<Layout
  title={`${service.title} | BTON`}
  description={service.metaDescription}
>
  <Header solid />

  <main>
    <section class="svc-hero">
      <div class="container svc-hero__inner">
        <div class="svc-hero__text">
          <nav class="svc-hero__crumbs" aria-label="Drobtinice">
            <a href="/">Domov</a>
            <span aria-hidden="true">/</span>
            <a href="/#storitve">Storitve</a>
            <span aria-hidden="true">/</span>
            <span aria-current="page">{service.title}</span>
          </nav>
          <h1 class="svc-hero__title">{service.title}</h1>
          <p class="svc-hero__lead">{service.lead}</p>
          <div class="svc-hero__actions">
            <a href="/#kontakt" class="btn btn--light">Pošlji povpraševanje</a>
            <a href={phoneHref} class="btn btn--outline-light">{phoneDisplay}</a>
          </div>
        </div>
        <div class="svc-hero__media">
          <Picture
            src={service.photo}
            alt={service.alt}
            formats={['avif', 'webp']}
            widths={[480, 768, 1024]}
            sizes="(max-width: 900px) 100vw, 44vw"
            quality={58}
            class="svc-hero__img"
            loading="eager"
          />
        </div>
      </div>
    </section>

    <section class="section svc-content">
      <div class="container svc-content__inner">
        <article class="svc-article reveal">
          <span class="eyebrow">O storitvi</span>
          <h2 class="svc-article__title">Kaj lahko pričakujete</h2>
          {service.detail.map((p) => <p>{p}</p>)}
          {
            service.cta && (
              <a
                href={service.cta.href}
                class="btn btn--ghost svc-article__cta"
                target="_blank"
                rel="noopener noreferrer"
              >
                {service.cta.label}
              </a>
            )
          }

          <section class="svc-section">
            <h2 class="svc-section__title">Kam se vgrajuje</h2>
            <p>{service.whereIntro}</p>
            <ul class="svc-chips">
              {service.idealFor.map((item) => <li>{item}</li>)}
            </ul>
          </section>

          <section class="svc-section">
            <h2 class="svc-section__title">Predpriprava</h2>
            <ul class="svc-checklist">
              {
                service.preparation.map((item) => (
                  <li>
                    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                      <path d="m5 12 5 5L19 8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    {item}
                  </li>
                ))
              }
            </ul>
          </section>

          <section class="svc-section">
            <h2 class="svc-section__title">Kako se vgrajuje</h2>
            <ol class="svc-steps">
              {
                service.process.map((step, i) => (
                  <li class="svc-step">
                    <span class="svc-step__num" aria-hidden="true">{i + 1}</span>
                    <div>
                      <h3 class="svc-step__title">{step.title}</h3>
                      <p>{step.text}</p>
                    </div>
                  </li>
                ))
              }
            </ol>
          </section>

          <section class="svc-section">
            <h2 class="svc-section__title">Koliko časa traja</h2>
            <p>{service.duration.text}</p>
          </section>

          <section class="svc-section">
            <h2 class="svc-section__title">Okvirna cena</h2>
            <p>{service.price.text}</p>
          </section>
        </article>

        <aside class="svc-aside reveal">
          <div class="svc-aside__card">
            <h3>Na hitro</h3>
            <dl class="svc-facts">
              <div class="svc-facts__row">
                <dt>Trajanje</dt>
                <dd>{service.duration.short}</dd>
              </div>
              <div class="svc-facts__row">
                <dt>Okvirna cena</dt>
                <dd>{service.price.short}</dd>
              </div>
              <div class="svc-facts__row">
                <dt>Ogled in ponudba</dt>
                <dd>Brezplačno</dd>
              </div>
              <div class="svc-facts__row">
                <dt>Garancija</dt>
                <dd>Na material in izvedbo</dd>
              </div>
            </dl>
          </div>
          <div class="svc-aside__card svc-aside__card--dark">
            <h3>Niste prepričani, ali je to prava izbira?</h3>
            <p>
              Pokličite ali pišite — pogledamo vaš prostor, svetujemo in
              pripravimo ponudbo brez obveznosti.
            </p>
            <a href="/#kontakt" class="btn btn--light svc-aside__btn">Pošlji povpraševanje</a>
            <a href={phoneHref} class="svc-aside__phone">{phoneDisplay}</a>
          </div>
        </aside>
      </div>
    </section>

    <ServiceGallery photos={service.photos} />

    <div class="svc-band" role="presentation">
      <Picture
        src={texture}
        alt=""
        formats={['avif', 'webp']}
        widths={[768, 1280, 1920]}
        sizes="100vw"
        quality={58}
        class="svc-band__img"
      />
    </div>

    <section class="section section--soft">
      <div class="container">
        <div class="section-head reveal">
          <span class="eyebrow">Storitve</span>
          <h2 class="section-title">Poglejte še</h2>
        </div>
        <div class="svc-others">
          {
            others.map((s) => (
              <a href={`/storitve/${s.id}`} class="svc-other reveal">
                <span class="svc-other__icon">
                  <Image src={s.icon} alt="" widths={[64, 128]} sizes="44px" />
                </span>
                <span class="svc-other__body">
                  <span class="svc-other__title">{s.title}</span>
                  <span class="svc-other__more">
                    Več o storitvi
                    <svg width="16" height="12" viewBox="0 0 16 12" aria-hidden="true">
                      <path d="M1 6h13M9 1l5 5-5 5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </span>
                </span>
              </a>
            ))
          }
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* ---------- Hero ---------- */
  .svc-hero {
    background: linear-gradient(160deg, var(--dark-1), var(--dark-2));
    padding-top: calc(var(--header-h) + clamp(2rem, 5vw, 4rem));
    padding-bottom: clamp(3rem, 6vw, 5rem);
    color: rgba(255, 255, 255, 0.85);
  }

  .svc-hero__inner {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    align-items: center;
    gap: clamp(2rem, 5vw, 4.5rem);
  }

  .svc-hero__crumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.76rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 1.4rem;
  }
  .svc-hero__crumbs a:hover {
    color: #fff;
  }
  .svc-hero__crumbs [aria-current] {
    color: rgba(255, 255, 255, 0.8);
  }

  .svc-hero__title {
    color: #fff;
    font-weight: 800;
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .svc-hero__lead {
    margin-top: 1.1rem;
    max-width: 520px;
    font-size: clamp(1rem, 1.5vw, 1.15rem);
  }

  .svc-hero__actions {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
  }

  .svc-hero__img {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--radius);
    box-shadow: var(--shadow-lg);
  }

  /* ---------- Content ---------- */
  .svc-content__inner {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: start;
  }

  .svc-article__title {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 800;
    margin: 0.5rem 0 1.2rem;
  }
  .svc-article p {
    color: var(--body);
    margin-bottom: 1rem;
  }
  .svc-article p:last-of-type {
    margin-bottom: 0;
  }
  .svc-article__cta {
    margin-top: 1.6rem;
  }

  /* ---------- Article sections ---------- */
  .svc-section {
    margin-top: clamp(2.4rem, 4vw, 3.2rem);
    padding-top: clamp(1.8rem, 3vw, 2.4rem);
    border-top: 1px solid var(--line);
  }
  .svc-section__title {
    font-size: clamp(1.3rem, 2.2vw, 1.6rem);
    font-weight: 800;
    margin-bottom: 1rem;
  }

  .svc-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 1.2rem;
  }
  .svc-chips li {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--ink);
    background: #fff;
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    padding: 0.45rem 1rem;
  }

  .svc-checklist {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .svc-checklist li {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    color: var(--body);
  }
  .svc-checklist svg {
    flex: none;
    margin-top: 0.2rem;
    color: var(--ink);
  }

  .svc-steps {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
  }
  .svc-step {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }
  .svc-step__num {
    flex: none;
    display: grid;
    place-items: center;
    width: 2.1rem;
    height: 2.1rem;
    border-radius: 50%;
    background: var(--ink);
    color: #fff;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
  }
  .svc-step__title {
    font-size: 1.02rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
  }
  .svc-step p {
    margin-bottom: 0;
  }

  .svc-aside {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    position: sticky;
    top: calc(var(--header-h) + 1rem);
  }

  .svc-aside__card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: clamp(1.4rem, 2.4vw, 1.9rem);
  }
  .svc-aside__card h3 {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.9rem;
  }

  .svc-facts {
    display: flex;
    flex-direction: column;
  }
  .svc-facts__row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.65rem 0;
    border-bottom: 1px solid var(--line);
  }
  .svc-facts__row:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  .svc-facts dt {
    color: var(--muted);
    font-size: 0.9rem;
  }
  .svc-facts dd {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--ink);
    text-align: right;
  }

  .svc-aside__card--dark {
    background: linear-gradient(160deg, var(--dark-1), var(--dark-2));
    border: none;
    color: rgba(255, 255, 255, 0.78);
  }
  .svc-aside__card--dark h3 {
    color: #fff;
  }
  .svc-aside__card--dark p {
    font-size: 0.95rem;
    margin-bottom: 1.2rem;
  }
  .svc-aside__btn {
    width: 100%;
  }
  .svc-aside__phone {
    display: block;
    margin-top: 0.9rem;
    text-align: center;
    font-family: var(--font-display);
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.04em;
  }
  .svc-aside__phone:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  /* ---------- Texture band ---------- */
  .svc-band {
    height: clamp(60px, 18vw, 120px);
    overflow: hidden;
  }
  .svc-band__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* ---------- Other services ---------- */
  .svc-others {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1rem, 2vw, 1.6rem);
  }

  .svc-other {
    display: flex;
    align-items: center;
    gap: 1.1rem;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1.2rem 1.4rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }
  .svc-other:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: transparent;
  }

  .svc-other__icon {
    flex: none;
    display: grid;
    place-items: center;
    width: 60px;
    height: 60px;
    border-radius: 14px;
    background: var(--ink);
  }
  .svc-other__icon :global(img) {
    width: 36px;
    height: 36px;
    object-fit: contain;
    /* icons are black line art — invert to white on the dark tile */
    filter: invert(1);
  }

  .svc-other__title {
    display: block;
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--ink);
  }
  .svc-other__more {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-top: 0.2rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .svc-other__more svg {
    transition: transform 0.3s ease;
  }
  .svc-other:hover .svc-other__more svg {
    transform: translateX(4px);
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 900px) {
    .svc-hero__inner {
      grid-template-columns: 1fr;
    }
    .svc-content__inner {
      grid-template-columns: 1fr;
    }
    .svc-aside {
      position: static;
    }
    .svc-others {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin-inline: auto;
    }
  }
</style>
