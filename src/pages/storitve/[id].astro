---
import { Picture } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ServiceGallery from '../../components/ServiceGallery.astro';
import FaqList from '../../components/FaqList.astro';
import texture from '../../assets/images/concrete-texture.jpeg';
import { services } from '../../data/services';

export function getStaticPaths() {
  return services.map((service) => ({
    params: { id: service.id },
    props: { service },
  }));
}

const { service } = Astro.props;
const others = services.filter((s) => s.id !== service.id);

const phoneDisplay = '+386 30 638 685';
const phoneHref = 'tel:+38630638685';

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    '@id': `${canonical}#service`,
    name: service.title,
    serviceType: service.title,
    description: service.metaDescription,
    url: canonical,
    provider: { '@id': 'https://bton.si/#business' },
    areaServed: { '@type': 'Country', name: 'Slovenija' },
    offers: {
      '@type': 'Offer',
      priceCurrency: 'EUR',
      priceSpecification: {
        '@type': 'UnitPriceSpecification',
        priceCurrency: 'EUR',
        minPrice: service.price.min,
        maxPrice: service.price.max,
        unitText: 'm²',
      },
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Domov', item: 'https://bton.si/' },
      { '@type': 'ListItem', position: 2, name: 'Storitve', item: 'https://bton.si/#storitve' },
      { '@type': 'ListItem', position: 3, name: service.title, item: canonical },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: service.faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
];
---

<Layout
  title={`${service.title} | Cena in izvedba | BTON`}
  description={service.metaDescription}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(schema)} />

  <Header solid />

  <main>
    <section class="svc-hero">
      <div class="container">
        <nav class="svc-hero__crumbs" aria-label="Drobtinice">
          <a href="/">Domov</a>
          <span aria-hidden="true">/</span>
          <a href="/#storitve">Storitve</a>
          <span aria-hidden="true">/</span>
          <span aria-current="page">{service.title}</span>
        </nav>

        <div class="svc-hero__inner">
          <div class="svc-hero__text">
            <p class="kicker svc-hero__kicker">Storitev</p>
            <h1 class="svc-hero__title">{service.title}<span>.</span></h1>
            <p class="svc-hero__lead">{service.lead}</p>
            <div class="svc-hero__actions">
              <a href="/#kontakt" class="btn">Pošlji povpraševanje</a>
              <a href={phoneHref} class="btn btn--ghost btn--bare">{phoneDisplay}</a>
            </div>
          </div>
          <div class="svc-hero__media">
            <Picture
              src={service.photo}
              alt={service.alt}
              formats={['avif', 'webp']}
              widths={[480, 768, 1024]}
              sizes="(max-width: 900px) 100vw, 44vw"
              quality={58}
              class="svc-hero__img"
              loading="eager"
            />
          </div>
        </div>

        <dl class="svc-hero__facts">
          <div>
            <dt>Trajanje</dt>
            <dd>{service.duration.short}</dd>
          </div>
          <div>
            <dt>Okvirna cena</dt>
            <dd>{service.price.short}</dd>
          </div>
          <div>
            <dt>Ogled in ponudba</dt>
            <dd>Brezplačno</dd>
          </div>
          <div>
            <dt>Garancija</dt>
            <dd>Na material in izvedbo</dd>
          </div>
        </dl>
      </div>
    </section>

    <section class="section svc-content">
      <div class="container svc-content__inner">
        <article class="svc-article reveal">
          <section class="svc-section svc-section--first">
            <h2 class="svc-section__title">Kaj lahko pričakujete</h2>
            {service.detail.map((p) => <p>{p}</p>)}
            {
              service.cta && (
                <a
                  href={service.cta.href}
                  class="btn btn--ghost svc-article__cta"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {service.cta.label}
                </a>
              )
            }
          </section>

          <section class="svc-section">
            <h2 class="svc-section__title">Kam se vgrajuje</h2>
            <p>{service.whereIntro}</p>
            <ul class="svc-chips">
              {service.idealFor.map((item) => <li>{item}</li>)}
            </ul>
          </section>

          <section class="svc-section">
            <h2 class="svc-section__title">Kaj ni vključeno</h2>
            <p>
              Izkop in priprava terena (zemeljska dela, odvoz materiala,
              nasutje in utrjevanje podlage) nista vključena v našo storitev.
              Če teh del še nimate urejenih, vas z veseljem povežemo s
              preverjenim podizvajalcem.
            </p>
          </section>

          <section class="svc-section">
            <h2 class="svc-section__title">Predpriprava</h2>
            <ul class="svc-checklist">
              {
                service.preparation.map((item) => (
                  <li>
                    <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
                      <path d="m5 12 5 5L19 8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    {item}
                  </li>
                ))
              }
            </ul>
          </section>

          <section class="svc-section">
            <h2 class="svc-section__title">Kako se vgrajuje</h2>
            <ol class="svc-steps">
              {
                service.process.map((step, i) => (
                  <li class="svc-step">
                    <span class="svc-step__num" aria-hidden="true">0{i + 1}</span>
                    <div>
                      <h3 class="svc-step__title">{step.title}</h3>
                      <p>{step.text}</p>
                    </div>
                  </li>
                ))
              }
            </ol>
          </section>

          <section class="svc-section">
            <h2 class="svc-section__title">Koliko časa traja</h2>
            <p>{service.duration.text}</p>
          </section>

          <section class="svc-section">
            <h2 class="svc-section__title">Okvirna cena</h2>
            <p>{service.price.text}</p>
          </section>

          <section class="svc-section">
            <h2 class="svc-section__title">Pogosta vprašanja</h2>
            <FaqList faqs={service.faqs} />
            {
              service.guide && (
                <p class="svc-guide">
                  Preberite tudi: <a href={service.guide.href}>{service.guide.label}</a>
                </p>
              )
            }
          </section>
        </article>

        <aside class="svc-aside reveal">
          <div class="svc-aside__card svc-aside__card--dark">
            <h3>Niste prepričani, ali je to prava izbira?</h3>
            <p>
              Pokličite ali pišite — pogledamo vaš prostor, svetujemo in
              pripravimo ponudbo brez obveznosti.
            </p>
            <a href="/#kontakt" class="btn btn--light svc-aside__btn">Pošlji povpraševanje</a>
            <a href={phoneHref} class="svc-aside__phone">{phoneDisplay}</a>
          </div>
        </aside>
      </div>
    </section>

    <ServiceGallery photos={service.photos} />

    <div class="svc-band" role="presentation">
      <Picture
        src={texture}
        alt=""
        formats={['avif', 'webp']}
        widths={[768, 1280, 1920]}
        sizes="100vw"
        quality={58}
        class="svc-band__img"
      />
    </div>

    <section class="section">
      <div class="container">
        <div class="sec-head reveal">
          <div class="sec-head__row">
            <span class="kicker">Storitve</span>
            <span class="kicker">Ostale obdelave</span>
          </div>
          <h2 class="sec-title">Poglejte še<em>.</em></h2>
        </div>
        <div class="svc-others">
          {
            others.map((s) => (
              <a href={`/storitve/${s.id}`} class="svc-other reveal">
                <span class="svc-other__title">{s.title}</span>
                <span class="svc-other__more">
                  Več o storitvi
                  <svg width="16" height="12" viewBox="0 0 16 12" aria-hidden="true">
                    <path d="M1 6h13M9 1l5 5-5 5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
              </a>
            ))
          }
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* ---------- Hero ---------- */
  .svc-hero {
    padding-top: calc(var(--header-h) + clamp(1.5rem, 4vw, 3rem));
    border-bottom: 1px solid var(--line);
    background: var(--paper);
  }

  .svc-hero__crumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    padding-bottom: 1.1rem;
    border-bottom: 1px solid var(--line);
  }
  .svc-hero__crumbs a:hover {
    color: var(--accent);
  }
  .svc-hero__crumbs [aria-current] {
    color: var(--ink);
  }

  .svc-hero__inner {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    align-items: center;
    gap: clamp(2rem, 5vw, 4.5rem);
    padding-block: clamp(2.5rem, 5vw, 4.5rem);
  }

  .svc-hero__kicker {
    margin-bottom: 1.1rem;
  }

  .svc-hero__title {
    font-size: clamp(2.5rem, 5.5vw, 4.5rem);
  }
  .svc-hero__title span {
    color: var(--accent);
  }

  .svc-hero__lead {
    margin-top: 1.2rem;
    max-width: 48ch;
    font-size: clamp(1rem, 1.5vw, 1.15rem);
  }

  .svc-hero__actions {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.9rem;
  }

  .svc-hero__img {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .svc-hero__facts {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    padding-block: 1.4rem;
    border-top: 1px solid var(--line);
    margin: 0;
  }
  .svc-hero__facts dt {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 0.66rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.2rem;
  }
  .svc-hero__facts dd {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 600;
    font-stretch: 106%;
    color: var(--ink);
    font-size: 1.05rem;
  }

  /* ---------- Content ---------- */
  .svc-content__inner {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: start;
  }

  .svc-article p {
    color: var(--body);
    margin-bottom: 1rem;
    max-width: 68ch;
  }
  .svc-article p:last-of-type {
    margin-bottom: 0;
  }
  .svc-article__cta {
    margin-top: 1.6rem;
  }

  /* ---------- Article sections ---------- */
  .svc-section {
    margin-top: clamp(2.4rem, 4vw, 3.4rem);
    padding-top: clamp(1.6rem, 3vw, 2.2rem);
    border-top: 1px solid var(--line);
  }
  .svc-section--first {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
  }
  .svc-section__title {
    font-size: clamp(1.35rem, 2.4vw, 1.8rem);
    margin-bottom: 1.1rem;
  }

  .svc-guide {
    margin-top: 1.6rem;
  }
  .svc-guide a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .svc-guide a:hover {
    color: var(--accent-deep);
  }

  .svc-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.2rem;
  }
  .svc-chips li {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink);
    border: 1px solid var(--line);
    padding: 0.45rem 0.9rem;
  }

  .svc-checklist {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .svc-checklist li {
    display: flex;
    align-items: flex-start;
    gap: 0.8rem;
    color: var(--body);
    padding-block: 0.8rem;
  }
  .svc-checklist li + li {
    border-top: 1px solid var(--line-soft);
  }
  .svc-checklist svg {
    flex: none;
    margin-top: 0.35rem;
    color: var(--accent);
  }

  .svc-steps {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 0;
  }
  .svc-step {
    display: flex;
    align-items: flex-start;
    gap: 1.2rem;
    padding-block: 1.1rem;
  }
  .svc-step + .svc-step {
    border-top: 1px solid var(--line-soft);
  }
  .svc-step__num {
    flex: none;
    display: grid;
    place-items: center;
    width: 2.4rem;
    height: 2.4rem;
    border: 1px solid var(--line);
    color: var(--accent);
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
  }
  .svc-step__title {
    font-size: 1.05rem;
    margin-bottom: 0.3rem;
  }
  .svc-step p {
    margin-bottom: 0;
  }

  /* ---------- Aside ---------- */
  .svc-aside {
    position: sticky;
    top: calc(var(--header-h) + 1.5rem);
  }

  .svc-aside__card--dark {
    background: var(--dark);
    color: var(--on-dark);
    padding: clamp(1.6rem, 2.6vw, 2.2rem);
  }
  .svc-aside__card--dark h3 {
    color: var(--on-dark-strong);
    font-size: 1.3rem;
    margin-bottom: 0.9rem;
  }
  .svc-aside__card--dark p {
    font-size: 0.95rem;
    margin-bottom: 1.4rem;
  }
  .svc-aside__btn {
    width: 100%;
  }
  .svc-aside__phone {
    display: block;
    margin-top: 1rem;
    text-align: center;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    color: var(--on-dark-strong);
  }
  .svc-aside__phone:hover {
    color: var(--accent-on-dark);
  }

  /* ---------- Texture band ---------- */
  .svc-band {
    height: clamp(60px, 18vw, 120px);
    overflow: hidden;
    border-block: 1px solid var(--line);
  }
  .svc-band__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* ---------- Other services ---------- */
  .svc-others {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--line);
    border-left: 1px solid var(--line);
  }

  .svc-other {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: clamp(1.4rem, 2.5vw, 2rem);
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    transition: background 0.25s ease;
  }
  .svc-other:hover {
    background: var(--paper-2);
  }

  .svc-other__title {
    font-family: var(--font-display);
    font-weight: 620;
    font-stretch: 110%;
    letter-spacing: -0.015em;
    font-size: 1.35rem;
    color: var(--ink);
  }
  .svc-other__more {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-top: 0.6rem;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .svc-other__more svg {
    transition: transform 0.3s ease;
  }
  .svc-other:hover .svc-other__more svg {
    transform: translateX(4px);
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 900px) {
    .svc-hero__inner {
      grid-template-columns: 1fr;
    }
    .svc-hero__facts {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.1rem;
    }
    .svc-content__inner {
      grid-template-columns: 1fr;
    }
    .svc-aside {
      position: static;
    }
    .svc-others {
      grid-template-columns: 1fr;
    }
  }
</style>
