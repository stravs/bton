---
import { Picture } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Contact from '../../components/Contact.astro';
import Footer from '../../components/Footer.astro';
import { services } from '../../data/services';

export function getStaticPaths() {
  return services.map((service) => ({ params: { id: service.id }, props: { service } }));
}

const { service } = Astro.props;
const canonicalPath = `/storitve/${service.id}/`;
const title = `${service.title} | Izdelava betonskih površin | BTON`;
const description = `${service.summary} BTON, Bled — svetovanje, priprava podlage, izvedba in zaščita betonskih površin po meri.`;
const serviceUrl = new URL(canonicalPath, Astro.site).href;
const serviceData = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${serviceUrl}#service`,
  name: service.title,
  description: service.detail.join(' '),
  url: serviceUrl,
  image: new URL(service.photo.src, Astro.site).href,
  provider: { '@id': 'https://bton.si/#organization' },
  areaServed: { '@type': 'Country', name: 'Slovenija' },
  serviceType: service.title,
};
const breadcrumbData = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Domov', item: 'https://bton.si/' },
    { '@type': 'ListItem', position: 2, name: 'Storitve', item: 'https://bton.si/#storitve' },
    { '@type': 'ListItem', position: 3, name: service.title, item: serviceUrl },
  ],
};
---

<Layout title={title} description={description} canonicalPath={canonicalPath} structuredData={[serviceData, breadcrumbData]}>
  <Header solid />
  <main class="service-page">
    <article class="container service-article">
      <nav class="breadcrumbs" aria-label="Drobtinice">
        <a href="/">Domov</a>
        <span aria-hidden="true">/</span>
        <a href="/#storitve">Storitve</a>
        <span aria-hidden="true">/</span>
        <span>{service.title}</span>
      </nav>

      <div class="service-hero">
        <div>
          <span class="eyebrow">Storitev BTON</span>
          <h1>{service.title}</h1>
          <p class="lead">{service.summary}</p>
          <div class="actions">
            <a href="/#kontakt" class="btn">Pošlji povpraševanje</a>
            <a href="tel:+38630638685" class="btn btn--ghost">Pokličite nas</a>
          </div>
        </div>
        <Picture
          src={service.photo}
          alt={service.alt}
          formats={['webp']}
          widths={[768, 1024]}
          sizes="(max-width: 900px) 100vw, 48vw"
          quality={62}
          class="service-hero__img"
          loading="eager"
        />
      </div>

      <section class="service-content" aria-labelledby="opis-storitve">
        <h2 id="opis-storitve">Opis storitve</h2>
        {service.detail.map((p) => <p>{p}</p>)}
        <h2>Za katere projekte je storitev primerna?</h2>
        <p>
          Storitev je primerna za zasebne in poslovne zunanje ali notranje površine,
          kjer so pomembni trpežnost, varnost, estetski videz in enostavno vzdrževanje.
          Za natančen predlog izvedbe nas kontaktirajte z opisom lokacije, velikostjo
          površine in želenim zaključnim videzom.
        </p>
      </section>
    </article>
    <Contact />
  </main>
  <Footer />
</Layout>

<style>
  .service-page { padding-top: 70px; }
  .service-article { padding-block: clamp(2rem, 5vw, 4rem); }
  .breadcrumbs { display:flex; flex-wrap:wrap; gap:.55rem; color:var(--muted); font-size:.92rem; margin-bottom:2rem; }
  .breadcrumbs a { color:var(--ink); text-decoration:underline; text-underline-offset:3px; }
  .service-hero { display:grid; grid-template-columns: 1fr 1fr; gap:clamp(2rem,5vw,4rem); align-items:center; }
  h1 { font-size:clamp(2.2rem,5vw,4rem); margin:.5rem 0 1rem; }
  .lead { font-size:clamp(1.05rem,1.7vw,1.25rem); color:var(--body); }
  .actions { display:flex; flex-wrap:wrap; gap:1rem; margin-top:2rem; }
  .service-hero__img { width:100%; height:auto; aspect-ratio:4/3; object-fit:cover; border-radius:var(--radius); box-shadow:var(--shadow-md); }
  .service-content { max-width: 860px; margin-top: clamp(3rem, 6vw, 5rem); }
  .service-content h2 { font-size:clamp(1.5rem,3vw,2.1rem); margin:2rem 0 1rem; }
  .service-content p { color:var(--body); margin-bottom:1rem; }
  @media (max-width: 900px) { .service-hero { grid-template-columns:1fr; } }
</style>
