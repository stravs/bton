---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import ServiceDetails from '../components/ServiceDetails.astro';
import WhyUs from '../components/WhyUs.astro';
import Faq from '../components/Faq.astro';
import Gallery from '../components/Gallery.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import { services, faqs } from '../data/services';

const title = 'BTON | Nizke gradnje in betonske površine | Bled, Slovenija';
const description = 'Strokovno izdelane zunanje betonske površine, kjer se estetika prepleta z vzdržljivostjo. V podjetju BTON ustvarjamo unikatne in celovite rešitve, prilagojene vašemu slogu in prostoru.';
const serviceCatalogData = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  '@id': 'https://bton.si/#storitve',
  name: 'Storitve BTON',
  itemListElement: services.map((service, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: service.title,
    url: `https://bton.si/#${service.id}`,
    description: service.summary,
  })),
};
const faqData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': 'https://bton.si/#faq-schema',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.q,
    acceptedAnswer: { '@type': 'Answer', text: faq.a },
  })),
};
---

<Layout title={title} description={description} structuredData={[serviceCatalogData, faqData]}>
  <Header />
  <main>
    <Hero />
    <Services />
    <ServiceDetails />
    <WhyUs />
    <Faq />
    <Gallery />
    <Contact />
  </main>
  <Footer />
</Layout>
